# API base URL (no trailing slash). Default: http://localhost:8080/api
# REACT_APP_API_URL=http://localhost:8080/api

# Google OAuth 2.0 Web client ID for "Continue with Google" on the login page.
# Create credentials at https://console.cloud.google.com/apis/credentials
# REACT_APP_GOOGLE_CLIENT_ID=

# Facebook App ID for "Continue with Facebook" on the login page.
# Create an app at https://developers.facebook.com/
# REACT_APP_FACEBOOK_APP_ID=

# reCAPTCHA v2 site key (contact form and settings support form)
# REACT_APP_RECAPTCHA_SITE_KEY=

# Optional: demo video URL for the homepage "View Demo" modal (e.g. https://www.youtube.com/embed/VIDEO_ID)
# REACT_APP_DEMO_VIDEO_URL=

# Optional: force Google Calendar iframe embed src (calendar id / email). If unset, uses the Google account
# from Settings → Connect Google (recommended so it matches events pushed to that account).
# REACT_APP_GOOGLE_CALENDAR_EMBED_ID=
